# Copy this to .env and fill in your real values.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/fifth_avenue_internal?retryWrites=true&w=majority

# RapidAPI key for Instagram Scraper Stable API (used by Add Creator auto-fetch)
RAPIDAPI_KEY=your_rapidapi_key_here

PORT=4000
